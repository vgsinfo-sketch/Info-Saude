{
  "entities": {
    "usuarios": {
      "title": "Usuário de Saúde",
      "description": "Informações de saúde de um usuário vinculadas a um ID único.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "ID único do cartão (ex: INFO-001)" },
        "nome_completo": { "type": "string" },
        "cpf": { "type": "string" },
        "cartao_sus": { "type": "string" },
        "tipo_sanguineo": { "type": "string", "enum": ["A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-"] },
        "alergias": { "type": "string" },
        "medicamentos": { "type": "string" },
        "condicoes_preexistentes": { "type": "string" },
        "ultima_vacina": { "type": "string" },
        "contatos_emergencia": { "type": "string" },
        "telefone": { "type": "string" },
        "data_nascimento": { "type": "string", "format": "date", "description": "Data de nascimento do usuário" },
        "sexo": { "type": "string", "enum": ["Masculino", "Feminino", "Outro", "Não informado"], "description": "Gênero do usuário" },
        "observacoes": { "type": "string", "description": "Observações administrativas internas" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "Papel do usuário no sistema" },
        "plano_saude_nome": { "type": "string", "description": "Nome do plano de saúde" },
        "plano_saude_numero": { "type": "string", "description": "Número do cartão do plano" },
        "plano_saude_tipo": { "type": "string", "description": "Tipo do plano" },
        "anexos": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "nome": { "type": "string" },
              "url": { "type": "string" },
              "path": { "type": "string" },
              "data": { "type": "string", "format": "date-time" },
              "tipo": { "type": "string", "enum": ["laudo", "receita"] }
            }
          }
        }
      },
      "required": ["id", "nome_completo", "cpf"]
    }
  },
  "firestore": {
    "/usuarios/{userId}": {
      "schema": "usuarios",
      "description": "Coleção de usuários de saúde."
    },
    "/usuarios/{userId}/anexos_data/{anexoId}": {
      "schema": {
        "type": "object",
        "properties": {
          "content": { "type": "string", "description": "Base64 content of the file" },
          "mimeType": { "type": "string", "description": "MIME type of the file" }
        },
        "required": ["content", "mimeType"]
      },
      "description": "Subcoleção para armazenar o conteúdo binário (Base64) dos anexos"
    }
  }
}
