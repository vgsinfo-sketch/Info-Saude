rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /fotos/{allPaths=**} {
      // Qualquer um pode ver as fotos (para emergência)
      allow read: if true;
      // Apenas usuários logados podem fazer upload
      allow write: if request.auth != null;
    }
    match /anexos/{userId}/{allPaths=**} {
      // Apenas o dono pode ver e subir seus anexos
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
